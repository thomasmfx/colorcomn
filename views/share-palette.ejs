<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head-boilerplate') %>
    <script src="/js/paletteManager.js" type="module" defer></script>
</head>
<body>
    <%- include('partials/header', { currentRoute: 'share' }) %>
    <main class="main self-center center">
        <form action="/palettes" method="POST" class="form palette-form" id="palette-form">
            <div class="form-field">
                <div class="form-field__header">
                    <span id="colorsLabel" class="form-field__label">Colors</span>
                    <button type="button"
                            class="btn-add-color"
                            aria-label="Add color"
                            aria-controls="colorModal">
                        <i class='bx bx-plus-circle' aria-hidden="true"></i>
                    </button>
                </div>

                <div class="palette-container">
                    <ul class="palette-colors list gap--s" aria-labelledby="colorsLabel">
                        <!-- Colors will be added here dynamically -->
                        <li class="palette-colors__item">
                            <button type="button" class="palette-colors__btn-color" aria-label="Remove color">
<!--                                <i class='bx bx-x-circle palette-colors__btn-color-icon' aria-hidden="true"></i>-->
                            </button>
                        </li>
                        <li class="palette-colors__item">
                            <button type="button" class="palette-colors__btn-color" aria-label="Remove color">
<!--                                <i class='bx bx-x-circle palette-colors__btn-color-icon' aria-hidden="true"></i>-->
                            </button>
                        </li>
                        <li class="palette-colors__item">
                            <button type="button" class="palette-colors__btn-color" aria-label="Remove color">
<!--                                <i class='bx bx-x-circle palette-colors__btn-color-icon' aria-hidden="true"></i>-->
                            </button>
                        </li>
                        <li class="palette-colors__item">
                            <button type="button" class="palette-colors__btn-color" aria-label="Remove color">
<!--                                <i class='bx bx-x-circle palette-colors__btn-color-icon' aria-hidden="true"></i>-->
                            </button>
                        </li>
                        <li class="palette-colors__item">
                            <button type="button" class="palette-colors__btn-color" aria-label="Remove color">
<!--                                <i class='bx bx-x-circle palette-colors__btn-color-icon' aria-hidden="true"></i>-->
                            </button>
                        </li>
                    </ul>
                    <input type="hidden" name="colors" id="selectedColorsInput">
                </div>
            </div>

            <div class="form-field">
                <input type="text" class="input-palette-name" aria-label="Palette name" id="palette-name" placeholder="Palette name" required>
            </div>
            <button type="submit" class="btn-submit">Share</button>
        </form>
    </main>

    <%- include('partials/color-selection-modal', { colors: colors }) %>
</body>